# API secret used for Auth0 Management API client credentials flow.
AUTH0_MANAGEMENT_CLIENT_SECRET=replace-with-auth0-management-client-secret

# Client build-time Auth0 settings.
VITE_AUTH_AUTHORITY=https://your-tenant.auth0.com/
VITE_AUTH_CLIENT_ID=your-spa-client-id
VITE_AUTH_SCOPE=openid profile email
VITE_AUTH_AUDIENCE=kauppalista-api
